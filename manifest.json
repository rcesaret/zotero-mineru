{
	"manifest_version": 2,
	"name": "Zotero MinerU Parser",
	"version": "0.1.57",
	"description": "Parse PDF attachments with MinerU API and save results as Markdown",
	"author": "lisontowind",
	"homepage_url": "https://github.com/lisontowind/zotero-mineru",
	"icons": {
		"16": "icon16.svg",
		"48": "icon.svg",
		"96": "icon.svg"
	},
	"applications": {
		"zotero": {
			"id": "zotero-mineru@example.com",
			"update_url": "https://raw.githubusercontent.com/lisontowind/zotero-mineru/main/updates.json",
			"strict_min_version": "8.0",
			"strict_max_version": "9.0.*"
		}
	}
}
